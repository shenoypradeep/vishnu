<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vedic Space | Meditations</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    :root {
      --blue:#1e3a8a;
      --gold:#fbbf24;
      --bg:#0f172a;
      --card:rgba(255,255,255,0.06);
      --border:rgba(251,191,36,0.25);
      --text:#f8fafc;
      --muted:#cbd5e1;
      --radius:20px;
      --sidebar:300px;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    body{
      font-family:Inter,sans-serif;
      background:linear-gradient(135deg,#1e3a8a,#0f172a);
      color:var(--text);
      min-height:100vh;
    }

    .app{display:flex;flex-direction:column}

    /* Desktop Sidebar */
    .sidebar{
      width:var(--sidebar);
      position:fixed;
      inset:0 auto 0 0;
      background:rgba(30,58,138,0.95);
      border-right:1px solid var(--border);
      padding:1.5rem;
      display:flex;
      flex-direction:column;
      gap:1.25rem;
    }

    .logo{
      font-family:Playfair Display,serif;
      font-size:1.4rem;
      font-weight:600;
    }

    .sidebar h1{
      font-family:Playfair Display,serif;
      font-weight:400;
      line-height:1.2;
    }

    .sidebar h1 span{color:var(--gold)}

    .search input{
      width:100%;
      padding:0.9rem 1.1rem;
      border-radius:30px;
      border:2px solid var(--border);
      background:rgba(255,255,255,0.1);
      color:white;
      font-size:1rem;
    }

    .search input::placeholder{
      color:var(--muted);
    }

    .search input:focus{
      outline:none;
      border-color:var(--gold);
    }

    .count{
      font-size:0.85rem;
      color:var(--muted);
    }

    /* Redesigned mobile header - compact, sleek sticky bar */
    .mobile-header{
      display:none;
      background:rgba(30,58,138,0.98);
      backdrop-filter:blur(10px);
      -webkit-backdrop-filter:blur(10px);
      position:sticky;
      top:0;
      z-index:100;
      border-bottom:1px solid var(--border);
    }

    .mobile-header-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:0.75rem 1rem;
    }

    .mobile-logo{
      font-family:Playfair Display,serif;
      font-size:1.1rem;
      font-weight:600;
      color:var(--gold);
    }

    .mobile-count{
      font-size:0.75rem;
      color:var(--muted);
      background:rgba(255,255,255,0.1);
      padding:0.25rem 0.6rem;
      border-radius:12px;
    }

    .mobile-search{
      padding:0 1rem 0.75rem;
    }

    .mobile-search input{
      width:100%;
      padding:0.65rem 1rem;
      border-radius:25px;
      border:1.5px solid var(--border);
      background:rgba(255,255,255,0.08);
      color:white;
      font-size:0.9rem;
    }

    .mobile-search input::placeholder{
      color:var(--muted);
    }

    .mobile-search input:focus{
      outline:none;
      border-color:var(--gold);
      background:rgba(255,255,255,0.12);
    }

    /* Main */
    main{
      margin-left:var(--sidebar);
      padding:3rem;
      width:100%;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(360px,1fr));
      gap:1.5rem;
    }

    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:2rem;
      transition:.3s;
    }

    .card:hover{
      transform:translateY(-6px);
      box-shadow:0 25px 60px rgba(0,0,0,.35);
    }

    .badge{
      display:inline-block;
      background:linear-gradient(135deg,#fbbf24,#f59e0b);
      color:#1e3a8a;
      font-size:0.7rem;
      font-weight:700;
      padding:0.35rem 0.9rem;
      border-radius:20px;
      margin-bottom:1rem;
      text-transform:uppercase;
      letter-spacing:0.08em;
    }

    .card h2{
      font-family:Playfair Display,serif;
      font-size:1.6rem;
      font-weight:400;
      margin-bottom:0.5rem;
    }

    .desc{
      color:var(--muted);
      font-size:1rem;
      line-height:1.6;
      margin-bottom:1rem;
    }

    audio{
      width:100%;
      margin-top:0.5rem;
      border-radius:8px;
    }

    .file{
      margin-top:0.75rem;
      font-size:0.75rem;
      color:var(--muted);
      font-family:monospace;
    }

    .empty{
      text-align:center;
      grid-column:1/-1;
      padding:5rem 2rem;
      color:var(--muted);
    }

    /* Improved mobile responsive styles */
    @media(max-width:900px){
      .sidebar{display:none}
      .mobile-header{display:block}
      .app{flex-direction:column}
      main{
        margin:0;
        padding:1rem;
        min-height:calc(100vh - 100px);
      }
      .cards{
        grid-template-columns:1fr;
        gap:1rem;
      }
      .card{
        padding:1.25rem;
      }
      .card h2{
        font-size:1.25rem;
      }
      .desc{
        font-size:0.9rem;
      }
    }

    @media(max-width:400px){
      .mobile-header-top{
        padding:0.6rem 0.75rem;
      }
      .mobile-logo{
        font-size:1rem;
      }
      .mobile-search{
        padding:0 0.75rem 0.6rem;
      }
      .mobile-search input{
        padding:0.55rem 0.85rem;
        font-size:0.85rem;
      }
      main{
        padding:0.75rem;
      }
      .card{
        padding:1rem;
        border-radius:14px;
      }
      .card h2{
        font-size:1.1rem;
      }
    }
  </style>
</head>
<body>

<div class="app">

  <!-- Redesigned mobile header - compact top bar with logo + count, search below -->
  <header class="mobile-header">
    <div class="mobile-header-top">
      <div class="mobile-logo">Vedic Space</div>
      <div class="mobile-count"><span id="count-mobile">0</span> meditations</div>
    </div>
    <div class="mobile-search">
      <input id="search-mobile" placeholder="Search meditations..." autocomplete="off">
    </div>
  </header>

  <!-- Desktop Sidebar -->
  <aside class="sidebar">
    <div class="logo">Vedic Space</div>

    <h1><span>Sādhana</span><br>Guided Meditations</h1>

    <div class="search">
      <input id="search" placeholder="Search meditations…" autocomplete="off">
    </div>

    <div class="count">
      Showing <strong id="count">0</strong> meditations
    </div>
  </aside>

  <main>
    <div class="cards" id="cards"></div>
  </main>

</div>

<script>
const meditations = [
  {
    id:1,
    title:"Gurudev Hari Om Meditation",
    file:"./audio/hari_om_meditation.mp3",
    description:"A gentle opening meditation invoking Hari Om for grounding and inner alignment."
  },
  {
    id:2,
    title:"Gurudev Om Namah Shivaya",
    file:"./audio/powerful_om_namah_shivaya.mp3",
    description:"Mantra-based Shiva dhyāna cultivating stillness and awareness."
  }
];

const cards=document.getElementById("cards");
const searchDesktop=document.getElementById("search");
const searchMobile=document.getElementById("search-mobile");
const countDesktop=document.getElementById("count");
const countMobile=document.getElementById("count-mobile");

function updateCount(num){
  countDesktop.textContent=num;
  countMobile.textContent=num;
}

function render(list){
  cards.innerHTML="";
  updateCount(list.length);

  if(!list.length){
    cards.innerHTML=`<div class="empty">No meditations found</div>`;
    return;
  }

  list.forEach(m=>{
    const el=document.createElement("div");
    el.className="card";
    el.innerHTML=`
      <span class="badge">Meditation</span>
      <h2>${m.title}</h2>
      <p class="desc">${m.description||""}</p>
      <audio controls preload="none">
        <source src="${m.file}" type="audio/mpeg">
      </audio>
      <div class="file">${m.file.split('/').pop()}</div>
    `;
    cards.appendChild(el);
  });
}

function filterMeditations(query){
  const q=query.toLowerCase();
  return meditations.filter(m=>
    m.title.toLowerCase().includes(q) ||
    m.file.toLowerCase().includes(q) ||
    (m.description && m.description.toLowerCase().includes(q))
  );
}

searchDesktop.addEventListener("input",e=>{
  const q=e.target.value;
  searchMobile.value=q;
  render(filterMeditations(q));
});

searchMobile.addEventListener("input",e=>{
  const q=e.target.value;
  searchDesktop.value=q;
  render(filterMeditations(q));
});

render(meditations);
</script>

</body>
</html>
